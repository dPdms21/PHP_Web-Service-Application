    "body": [
        {
            "utteranceID": "U01",
            "turnID": "T01",
            "participantID": "P01",
            "date": "2021-09-16",
            "time": "00:00:00",
            "utterance": "너는 고스톱 잘 쳐?"
        },
        {
            "utteranceID": "U02",
            "turnID": "T02",
            "participantID": "P02",
            "date": "2021-09-16",
            "time": "00:00:00",
            "utterance": "응! 나 어릴 때부터 할머니랑 많이 해서 완전 타짜야 키키"
        },
        {
            "utteranceID": "U03",
            "turnID": "T03",
            "participantID": "P01",
            "date": "2021-09-16",
            "time": "00:00:00",
            "utterance": "아 진짜?! 오~ 고스톱이 치매 예방에 좋다던데 치매 안 걸리겠는데?!"
        },
        {
            "utteranceID": "U04",
            "turnID": "T04",
            "participantID": "P02",
            "date": "2021-09-16",
            "time": "00:00:00",
            "utterance": "키키 글쎄  우리가 하는 게 지금부터도 예방이 되는 건가?"
        },
        {
            "utteranceID": "U05",
            "turnID": "T05",
            "participantID": "P01",
            "date": "2021-09-16",
            "time": "00:00:00",
            "utterance": "음... 아무래도 생각을 해야 되니까 뇌에 주름 좀 잡히면 치매 예방이 되지 않을까?"
        },
        {
            "utteranceID": "U06",
            "turnID": "T06",
            "participantID": "P02",
            "date": "2021-09-16",
            "time": "00:00:00",
            "utterance": "에? 주름이라니 키키 뇌에 활동량이 많아지는 건데~"
        },
        {
            "utteranceID": "U07",
            "turnID": "T06",
            "participantID": "P02",
            "date": "2021-09-16",
            "time": "00:00:00",
            "utterance": "우리는 지금도 이미 많잖아 키키"
        },
        {
            "utteranceID": "U08",
            "turnID": "T07",
            "participantID": "P01",
            "date": "2021-09-16",
            "time": "00:00:00",
            "utterance": "뇌에 활동량이 많아지면 주름이 많아지잖아~"
        },
        {
            "utteranceID": "U09",
            "turnID": "T08",
            "participantID": "P02",
            "date": "2021-09-16",
            "time": "00:00:00",
            "utterance": "그래? 주름이 펴져야 좋은 거야?"
        },
        {
            "utteranceID": "U10",
            "turnID": "T09",
            "participantID": "P01",
            "date": "2021-09-16",
            "time": "00:00:00",
            "utterance": "아니아니 키키 주름이 많아야 똑똑하대"
        },
        {
            "utteranceID": "U11",
            "turnID": "T10",
            "participantID": "P02",
            "date": "2021-09-16",
            "time": "00:00:00",
            "utterance": "그렇구나 하하 너는 고스톱 칠 줄 알아?"
        },
        {
            "utteranceID": "U12",
            "turnID": "T11",
            "participantID": "P01",
            "date": "2021-09-16",
            "time": "00:00:00",
            "utterance": "응 그냥 짝 맞추기 정도...? 키키"
        },
        {
            "utteranceID": "U13",
            "turnID": "T12",
            "participantID": "P02",
            "date": "2021-09-16",
            "time": "00:00:00",
            "utterance": "아 하하 영화 보면 도박장 같은 게 나오잖아~"
        },
        {
            "utteranceID": "U14",
            "turnID": "T12",
            "participantID": "P02",
            "date": "2021-09-16",
            "time": "00:00:00",
            "utterance": "실제로 그런 게 있을까?"
        },
        {
            "utteranceID": "U15",
            "turnID": "T13",
            "participantID": "P01",
            "date": "2021-09-16",
            "time": "00:00:00",
            "utterance": "응 실제로 있대~!"
        },
        {
            "utteranceID": "U16",
            "turnID": "T13",
            "participantID": "P01",
            "date": "2021-09-16",
            "time": "00:00:00",
            "utterance": "진짜 비닐 하우스 안에서 도박 한다고 하우스라던데"
        },
        {
            "utteranceID": "U17",
            "turnID": "T14",
            "participantID": "P02",
            "date": "2021-09-16",
            "time": "00:00:00",
            "utterance": "우와 정말? 영화에만 있을 거 같은데 실제로 존재한다니... 신기하고 무섭다..."
        },
        {
            "utteranceID": "U18",
            "turnID": "T15",
            "participantID": "P01",
            "date": "2021-09-16",
            "time": "00:00:00",
            "utterance": "그러니까 키키 나중에 같이 구경이나 한 번 갔다 와보자~"
        },
        {
            "utteranceID": "U19",
            "turnID": "T16",
            "participantID": "P02",
            "date": "2021-09-16",
            "time": "00:00:00",
            "utterance": "우리도 갈 수 있는 곳인가? 괜히 떨리네 키키 그래!"
        }
    ]
}