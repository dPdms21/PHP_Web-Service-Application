        {
            "utteranceID": "U13",
            "turnID": "T07",
            "participantID": "P01",
            "date": "2020-07-31",
            "time": "02:38:00",
            "utterance": "영국이 다 조져놔서"
        },
        {
            "utteranceID": "U14",
            "turnID": "T07",
            "participantID": "P01",
            "date": "2020-07-31",
            "time": "02:38:00",
            "utterance": "기름에 취했는지"
