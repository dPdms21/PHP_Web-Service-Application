            "turnID": "T05",
            "participantID": "P01",
            "date": "2020-06-24",
            "time": "13:03:00",
            "utterance": "파스 붙이고"
        },
        {
            "utteranceID": "U14",
            "turnID": "T06",
            "participantID": "P02",
            "date": "2020-06-24",
            "time": "13:03:00",
            "utterance": "어쩌냐..."
