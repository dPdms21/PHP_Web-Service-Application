        {
            "utteranceID": "U07",
            "turnID": "T03",
            "participantID": "P01",
            "date": "2020-06-24",
            "time": "12:57:00",
            "utterance": "그래서 역에서 하나 샀어"
        },
        {
            "utteranceID": "U08",
            "turnID": "T04",
            "participantID": "P02",
            "date": "2020-06-24",
            "time": "13:01:00",
            "utterance": "이구 그랬구나 잘했어 잘했어"
