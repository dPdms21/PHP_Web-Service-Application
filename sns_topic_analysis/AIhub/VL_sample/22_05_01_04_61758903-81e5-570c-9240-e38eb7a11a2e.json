        {
            "utteranceID": "U02",
            "turnID": "T01",
            "participantID": "P01",
            "date": "2021-01-06",
            "time": "10:40:00",
            "utterance": "이미 코코 들어올땐 한국에"
        },
        {
            "utteranceID": "U03",
            "turnID": "T01",
            "participantID": "P01",
            "date": "2021-01-06",
            "time": "10:40:00",
            "utterance": "짭 버블티 다 깔린 후여서"
        },
        {
            "utteranceID": "U04",
            "turnID": "T01",
            "participantID": "P01",
            "date": "2021-01-06",
            "time": "10:40:00",
            "utterance": "ㅋㅋㅋㅋㅋㅋㅋ"
