    "body": [
        {
            "utteranceID": "U01",
            "turnID": "T01",
            "participantID": "P01",
            "date": "2021-10-19",
            "time": "00:00:00",
            "utterance": "나 해외원화결제서비스차단 풀렸더라ㅜ"
        },
        {
            "utteranceID": "U02",
            "turnID": "T02",
            "participantID": "P02",
            "date": "2021-10-19",
            "time": "00:00:00",
            "utterance": "거기서도 쇼핑은 계속 되는구나"
        },
        {
            "utteranceID": "U03",
            "turnID": "T02",
            "participantID": "P02",
            "date": "2021-10-19",
            "time": "00:00:00",
            "utterance": "그거는 왜풀리는데?  그럼 알리가 원화로 결제 된거야?"
        },
        {
            "utteranceID": "U04",
            "turnID": "T03",
            "participantID": "P01",
            "date": "2021-10-19",
            "time": "00:00:00",
            "utterance": "알리에서 결제한거 달러자나 키키"
        },
        {
            "utteranceID": "U05",
            "turnID": "T03",
            "participantID": "P01",
            "date": "2021-10-19",
            "time": "00:00:00",
            "utterance": "상생땜시 국카결제했는데 차단됐어야되는데"
        },
        {
            "utteranceID": "U06",
            "turnID": "T03",
            "participantID": "P01",
            "date": "2021-10-19",
            "time": "00:00:00",
            "utterance": "원화로 결제해야된디 달러로 결제가 됐어"
        },
        {
            "utteranceID": "U07",
            "turnID": "T03",
            "participantID": "P01",
            "date": "2021-10-19",
            "time": "00:00:00",
            "utterance": "달러는 이중환전수수료 붙어서 차단해놨는딩ㅜ"
        },
        {
            "utteranceID": "U08",
            "turnID": "T04",
            "participantID": "P02",
            "date": "2021-10-19",
            "time": "00:00:00",
            "utterance": "아닌데. 원화가 이중수수료일껄?"
        },
        {
            "utteranceID": "U09",
            "turnID": "T05",
            "participantID": "P01",
            "date": "2021-10-19",
            "time": "00:00:00",
            "utterance": "엥? 그래?"
        },
        {
            "utteranceID": "U10",
            "turnID": "T05",
            "participantID": "P01",
            "date": "2021-10-19",
            "time": "00:00:00",
            "utterance": "아맞네 반대네 내가 원화로 결제한거네? 키키"
        },
        {
            "utteranceID": "U11",
            "turnID": "T05",
            "participantID": "P01",
            "date": "2021-10-19",
            "time": "00:00:00",
            "utterance": "해외통화인데 왜수수료가붙노 키키"
        },
        {
            "utteranceID": "U12",
            "turnID": "T06",
            "participantID": "P02",
            "date": "2021-10-19",
            "time": "00:00:00",
            "utterance": "키키 그건모르겠는데 여튼 그렇더라"
        },
        {
            "utteranceID": "U13",
            "turnID": "T06",
            "participantID": "P02",
            "date": "2021-10-19",
            "time": "00:00:00",
            "utterance": "이때까지 원화로 계속 했어?"
        },
        {
            "utteranceID": "U14",
            "turnID": "T07",
            "participantID": "P01",
            "date": "2021-10-19",
            "time": "00:00:00",
            "utterance": "아니 달러인가봐ㅋㄱㅋ"
        },
        {
            "utteranceID": "U15",
            "turnID": "T07",
            "participantID": "P01",
            "date": "2021-10-19",
            "time": "00:00:00",
            "utterance": "카드쓸려고 간만에 국카 꺼내들었는디 원화네 키키"
        },
        {
            "utteranceID": "U16",
            "turnID": "T08",
            "participantID": "P02",
            "date": "2021-10-19",
            "time": "00:00:00",
            "utterance": "오늘한게? 달러?"
        },
        {
            "utteranceID": "U17",
            "turnID": "T09",
            "participantID": "P01",
            "date": "2021-10-19",
            "time": "00:00:00",
            "utterance": "원화로 결제하면 환전수수료드는거네"
        }
    ]
}