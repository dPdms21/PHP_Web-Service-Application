    "body": [
        {
            "utteranceID": "U01",
            "turnID": "T01",
            "participantID": "P01",
            "date": "2021-09-17",
            "time": "00:00:00",
            "utterance": "나 어렸을 때 짱구 만화 캐릭터 좋아했는데 키키"
        },
        {
            "utteranceID": "U02",
            "turnID": "T02",
            "participantID": "P02",
            "date": "2021-09-17",
            "time": "00:00:00",
            "utterance": "짱구! 그리운 캐릭터네~ 예전에 짱구 진짜 재밌었는데~"
        },
        {
            "utteranceID": "U03",
            "turnID": "T03",
            "participantID": "P01",
            "date": "2021-09-17",
            "time": "00:00:00",
            "utterance": "키키 지금도 하고 있잖아 키키"
        },
        {
            "utteranceID": "U04",
            "turnID": "T04",
            "participantID": "P02",
            "date": "2021-09-17",
            "time": "00:00:00",
            "utterance": "지금도 하고 있어? 그거 완결 안 났어?"
        },
        {
            "utteranceID": "U05",
            "turnID": "T05",
            "participantID": "P01",
            "date": "2021-09-17",
            "time": "00:00:00",
            "utterance": "응 키키 계속 시즌 나오고 있는 걸로 앎 키키"
        },
        {
            "utteranceID": "U06",
            "turnID": "T06",
            "participantID": "P02",
            "date": "2021-09-17",
            "time": "00:00:00",
            "utterance": "우와~! 요즘에는 잘 안 봐서 몰랐네;"
        },
        {
            "utteranceID": "U07",
            "turnID": "T06",
            "participantID": "P02",
            "date": "2021-09-17",
            "time": "00:00:00",
            "utterance": "아직도 짱구는 할 수 있는 일이 많구나;"
        },
        {
            "utteranceID": "U08",
            "turnID": "T07",
            "participantID": "P01",
            "date": "2021-09-17",
            "time": "00:00:00",
            "utterance": "키키 요즘 짱구는 교훈을 준다더라고 키키"
        },
        {
            "utteranceID": "U09",
            "turnID": "T08",
            "participantID": "P02",
            "date": "2021-09-17",
            "time": "00:00:00",
            "utterance": "진짜? 대박~ 궁금하다 이번에 함 봐야겠구만!"
        },
        {
            "utteranceID": "U10",
            "turnID": "T09",
            "participantID": "P01",
            "date": "2021-09-17",
            "time": "00:00:00",
            "utterance": "키키 짱구에서 얼마나 큰 교훈을 줄지 키키"
        },
        {
            "utteranceID": "U11",
            "turnID": "T09",
            "participantID": "P01",
            "date": "2021-09-17",
            "time": "00:00:00",
            "utterance": "캐릭터 성격이랑 안 맞는데 키키"
        },
        {
            "utteranceID": "U12",
            "turnID": "T10",
            "participantID": "P02",
            "date": "2021-09-17",
            "time": "00:00:00",
            "utterance": "월래는 짱구 성인용 만화라고 하잖아. 키키"
        },
        {
            "utteranceID": "U13",
            "turnID": "T11",
            "participantID": "P01",
            "date": "2021-09-17",
            "time": "00:00:00",
            "utterance": "그러니까 키키 나 한번 일본판 봤다가 식겁하고 바로 껐잖아"
        },
        {
            "utteranceID": "U14",
            "turnID": "T12",
            "participantID": "P02",
            "date": "2021-09-17",
            "time": "00:00:00",
            "utterance": "나는 본 적은 없고 그냥 이야기만 들었었어~"
        },
        {
            "utteranceID": "U15",
            "turnID": "T12",
            "participantID": "P02",
            "date": "2021-09-17",
            "time": "00:00:00",
            "utterance": "그데 그것이 교육용이라니;"
        },
        {
            "utteranceID": "U16",
            "turnID": "T13",
            "participantID": "P01",
            "date": "2021-09-17",
            "time": "00:00:00",
            "utterance": "키키 보지 마 개식겁 키키 캐릭터랑 안 맞아 안 맞아~"
        },
        {
            "utteranceID": "U17",
            "turnID": "T14",
            "participantID": "P02",
            "date": "2021-09-17",
            "time": "00:00:00",
            "utterance": "키키 궁금하다 심히 그거 함 찾아봐야겠네~!"
        },
        {
            "utteranceID": "U18",
            "turnID": "T15",
            "participantID": "P01",
            "date": "2021-09-17",
            "time": "00:00:00",
            "utterance": "키키 굳이 추천하지는 않지만 보면 후기~"
        },
        {
            "utteranceID": "U19",
            "turnID": "T16",
            "participantID": "P02",
            "date": "2021-09-17",
            "time": "00:00:00",
            "utterance": "키키 딱히 진짜 열심히 볼 생각은 없지만 들으니까 내용이 궁금하기는 하네~ 키키"
        }
    ]
}