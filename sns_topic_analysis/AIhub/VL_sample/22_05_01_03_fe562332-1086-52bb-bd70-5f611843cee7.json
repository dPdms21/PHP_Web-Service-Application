        {
            "utteranceID": "U02",
            "turnID": "T02",
            "participantID": "P02",
            "date": "2020-12-21",
            "time": "16:00:00",
            "utterance": "토요일날가면되겠지??"
        },
        {
            "utteranceID": "U03",
            "turnID": "T03",
            "participantID": "P01",
            "date": "2020-12-21",
            "time": "16:00:00",
            "utterance": "넹넹"
        },
        {
            "utteranceID": "U04",
            "turnID": "T03",
            "participantID": "P01",
            "date": "2020-12-21",
            "time": "16:00:00",
            "utterance": "편한시간에 와도 된다니까"
        },
        {
            "utteranceID": "U05",
            "turnID": "T03",
            "participantID": "P01",
            "date": "2020-12-21",
            "time": "16:01:00",
            "utterance": "토요일에 가도 괜찮을거 같으다요!"
        },
        {
            "utteranceID": "U06",
            "turnID": "T04",
            "participantID": "P02",
            "date": "2020-12-21",
            "time": "16:14:00",
            "utterance": "그래 토요일날 갔다가오자"
        },
        {
            "utteranceID": "U07",
            "turnID": "T05",
            "participantID": "P01",
            "date": "2020-12-21",
            "time": "16:15:00",
            "utterance": "그러자요 그러자요"
        },
        {
            "utteranceID": "U08",
            "turnID": "T05",
            "participantID": "P01",
            "date": "2020-12-21",
            "time": "16:15:00",
            "utterance": "토요일에 호다닥 가서 검사결과 듣고 오자요!"
