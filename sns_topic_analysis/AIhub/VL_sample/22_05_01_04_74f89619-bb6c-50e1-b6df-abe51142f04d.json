            "participantID": "P02",
            "date": "2020-12-05",
            "time": "23:52:00",
            "utterance": "맞아~ 관광하기엔 최고지"
        },
        {
            "utteranceID": "U03",
            "turnID": "T03",
            "participantID": "P01",
            "date": "2020-12-05",
            "time": "23:52:00",
