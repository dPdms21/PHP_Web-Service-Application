    "body": [
        {
            "utteranceID": "U01",
            "turnID": "T01",
            "participantID": "P01",
            "date": "2021-11-11",
            "time": "00:00:00",
            "utterance": "최근에 백신 관련해서 청원이 올라왔대"
        },
        {
            "utteranceID": "U02",
            "turnID": "T02",
            "participantID": "P02",
            "date": "2021-11-11",
            "time": "00:00:00",
            "utterance": "최근에 백신 관련해서 왜 올라왔어?"
        },
        {
            "utteranceID": "U03",
            "turnID": "T03",
            "participantID": "P01",
            "date": "2021-11-11",
            "time": "00:00:00",
            "utterance": "40대 남성이 모더나 맞고 돌아가셨대"
        },
        {
            "utteranceID": "U04",
            "turnID": "T04",
            "participantID": "P02",
            "date": "2021-11-11",
            "time": "00:00:00",
            "utterance": "헐 진짜?"
        },
        {
            "utteranceID": "U05",
            "turnID": "T04",
            "participantID": "P02",
            "date": "2021-11-11",
            "time": "00:00:00",
            "utterance": "나도 모더나 맞았은데 괜찮았은데?"
        },
        {
            "utteranceID": "U06",
            "turnID": "T05",
            "participantID": "P01",
            "date": "2021-11-11",
            "time": "00:00:00",
            "utterance": "2차 접종 후에 하루도 안돼서 돌아가셨대"
        },
        {
            "utteranceID": "U07",
            "turnID": "T06",
            "participantID": "P02",
            "date": "2021-11-11",
            "time": "00:00:00",
            "utterance": "그럼 청원해서 어떻게 할 수 있는데?"
        },
        {
            "utteranceID": "U08",
            "turnID": "T07",
            "participantID": "P01",
            "date": "2021-11-11",
            "time": "00:00:00",
            "utterance": "우선은 청원만 올린 상태인 거 같아"
        },
        {
            "utteranceID": "U09",
            "turnID": "T08",
            "participantID": "P02",
            "date": "2021-11-11",
            "time": "00:00:00",
            "utterance": "그럼 누구를 벌 주는 거야?"
        },
        {
            "utteranceID": "U10",
            "turnID": "T09",
            "participantID": "P01",
            "date": "2021-11-11",
            "time": "00:00:00",
            "utterance": "우선 병원 측 과실이지 않을까?"
        },
        {
            "utteranceID": "U11",
            "turnID": "T10",
            "participantID": "P02",
            "date": "2021-11-11",
            "time": "00:00:00",
            "utterance": "병원 측 과실이라도 약이라는 게 안 맞을 수도 있잖아"
        },
        {
            "utteranceID": "U12",
            "turnID": "T11",
            "participantID": "P01",
            "date": "2021-11-11",
            "time": "00:00:00",
            "utterance": "복용하는 약이 있는데도 불구하고 2차 접종이 가능하다고 했다네"
        },
        {
            "utteranceID": "U13",
            "turnID": "T12",
            "participantID": "P02",
            "date": "2021-11-11",
            "time": "00:00:00",
            "utterance": "아 그래?"
        },
        {
            "utteranceID": "U14",
            "turnID": "T12",
            "participantID": "P02",
            "date": "2021-11-11",
            "time": "00:00:00",
            "utterance": "그럼 무조건 의사가 잘못했네"
        }
    ]
}