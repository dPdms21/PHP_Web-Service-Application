        {
            "utteranceID": "U07",
            "turnID": "T03",
            "participantID": "P01",
            "date": "2019-06-20",
            "time": "12:14:00",
            "utterance": "끊임없이 나오는구나"
        },
        {
            "utteranceID": "U08",
            "turnID": "T04",
            "participantID": "P02",
            "date": "2019-06-20",
            "time": "12:14:00",
