        {
            "utteranceID": "U08",
            "turnID": "T05",
            "participantID": "P01",
            "date": "2018-02-17",
            "time": "19:20:00",
            "utterance": "그냥 무는건 괜찮은데"
        },
        {
            "utteranceID": "U09",
            "turnID": "T06",
            "participantID": "P02",
            "date": "2018-02-17",
            "time": "19:20:00",
            "utterance": "개들은 모르지"
