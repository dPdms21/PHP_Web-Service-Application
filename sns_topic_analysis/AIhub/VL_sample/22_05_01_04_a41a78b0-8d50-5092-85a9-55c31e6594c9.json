    "body": [
        {
            "utteranceID": "U01",
            "turnID": "T01",
            "participantID": "P01",
            "date": "2020-12-10",
            "time": "00:57:00",
            "utterance": "근데 왜 딸까지 터짐?"
        },
        {
            "utteranceID": "U02",
            "turnID": "T02",
            "participantID": "P02",
            "date": "2020-12-10",
            "time": "00:57:00",
            "utterance": "그 부인이"
        },
        {
            "utteranceID": "U03",
            "turnID": "T02",
            "participantID": "P02",
            "date": "2020-12-10",
            "time": "00:57:00",
            "utterance": "딸이 이번에 사립학교 면접 보고왓다고"
        },
        {
            "utteranceID": "U04",
            "turnID": "T02",
            "participantID": "P02",
            "date": "2020-12-10",
            "time": "00:57:00",
            "utterance": "자기 딸은 사립합겨 보내서"
        },
        {
            "utteranceID": "U05",
            "turnID": "T02",
            "participantID": "P02",
            "date": "2020-12-10",
            "time": "00:57:00",
            "utterance": "하고싶은거 다 하게한다고"
        },
        {
            "utteranceID": "U06",
            "turnID": "T02",
            "participantID": "P02",
            "date": "2020-12-10",
            "time": "00:57:00",
            "utterance": "그랬거든"
        },
        {
            "utteranceID": "U07",
            "turnID": "T02",
            "participantID": "P02",
            "date": "2020-12-10",
            "time": "00:58:00",
            "utterance": "막 거기가 첼로 운동 머시기 머시기"
        },
        {
            "utteranceID": "U08",
            "turnID": "T02",
            "participantID": "P02",
            "date": "2020-12-10",
            "time": "00:58:00",
            "utterance": "다시켜주는 사립학굔가버"
        },
        {
            "utteranceID": "U09",
            "turnID": "T03",
            "participantID": "P01",
            "date": "2020-12-10",
            "time": "00:58:00",
            "utterance": "아 자기가 먼저 말 꺼냈네?"
        },
        {
            "utteranceID": "U10",
            "turnID": "T04",
            "participantID": "P02",
            "date": "2020-12-10",
            "time": "00:58:00",
            "utterance": "그게 그 지역 맘카페에 퍼지면서"
        },
        {
            "utteranceID": "U11",
            "turnID": "T05",
            "participantID": "P01",
            "date": "2020-12-10",
            "time": "00:58:00",
            "utterance": "누가 밝힌게 아니라?"
        },
        {
            "utteranceID": "U12",
            "turnID": "T06",
            "participantID": "P02",
            "date": "2020-12-10",
            "time": "00:58:00",
            "utterance": "엉"
        },
        {
            "utteranceID": "U13",
            "turnID": "T07",
            "participantID": "P01",
            "date": "2020-12-10",
            "time": "00:58:00",
            "utterance": "입이 문제여..."
        },
        {
            "utteranceID": "U14",
            "turnID": "T08",
            "participantID": "P02",
            "date": "2020-12-10",
            "time": "00:58:00",
            "utterance": "철구 딸이 무슨학교 사립학겨에 합격햇다더라"
        },
        {
            "utteranceID": "U15",
            "turnID": "T08",
            "participantID": "P02",
            "date": "2020-12-10",
            "time": "00:58:00",
            "utterance": "나는 내 자식이랑 같이 못보내겟다"
        },
        {
            "utteranceID": "U16",
            "turnID": "T08",
            "participantID": "P02",
            "date": "2020-12-10",
            "time": "00:59:00",
            "utterance": "이렇게 커진거어"
        },
        {
            "utteranceID": "U17",
            "turnID": "T08",
            "participantID": "P02",
            "date": "2020-12-10",
            "time": "00:59:00",
            "utterance": "근데 학교입장은 교육자입장에서 교육은 누구에게나 평등하게 기회를 줘야된다"
        },
        {
            "utteranceID": "U18",
            "turnID": "T08",
            "participantID": "P02",
            "date": "2020-12-10",
            "time": "00:59:00",
            "utterance": "부모가 어떤 출신이던간에"
        }
    ]
}