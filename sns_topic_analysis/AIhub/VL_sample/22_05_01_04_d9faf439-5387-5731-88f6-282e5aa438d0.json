            "participantID": "P01",
            "date": "2019-03-15",
            "time": "17:25:00",
            "utterance": "안그래도 자기네 점심마다 과일나온다고 엄청 자랑했음"
        },
        {
            "utteranceID": "U02",
            "turnID": "T02",
            "participantID": "P02",
            "date": "2019-03-15",
            "time": "17:25:00",
            "utterance": "유치원에서 과일나오면"
        },
        {
            "utteranceID": "U03",
            "turnID": "T02",
            "participantID": "P02",
            "date": "2019-03-15",
            "time": "17:25:00",
            "utterance": "감지덕지래요"
        },
        {
            "utteranceID": "U04",
            "turnID": "T03",
            "participantID": "P01",
            "date": "2019-03-15",
            "time": "17:25:00",
            "utterance": "그래??"
        },
        {
            "utteranceID": "U05",
            "turnID": "T04",
            "participantID": "P02",
            "date": "2019-03-15",
            "time": "17:25:00",
            "utterance": "유치원은 진짜"
        },
        {
            "utteranceID": "U06",
            "turnID": "T05",
            "participantID": "P01",
            "date": "2019-03-15",
            "time": "17:25:00",
            "utterance": "이게 무슨 자랑할건가했음"
        },
        {
            "utteranceID": "U07",
            "turnID": "T06",
            "participantID": "P02",
            "date": "2019-03-15",
            "time": "17:25:00",
            "utterance": "얼집보다 훨 구리다면서"
        },
        {
            "utteranceID": "U08",
            "turnID": "T06",
            "participantID": "P02",
            "date": "2019-03-15",
            "time": "17:25:00",
            "utterance": "얼집은 과일을 베이스로 깔았는데"
        },
        {
            "utteranceID": "U09",
            "turnID": "T07",
            "participantID": "P01",
            "date": "2019-03-15",
            "time": "17:26:00",
            "utterance": "ㅇㅇ 그러니까"
        }
    ]
