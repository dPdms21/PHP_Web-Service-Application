    "body": [
        {
            "utteranceID": "U01",
            "turnID": "T01",
            "participantID": "P01",
            "date": "2021-09-15",
            "time": "00:00:00",
            "utterance": "자기 지원금 신청했어?"
        },
        {
            "utteranceID": "U02",
            "turnID": "T02",
            "participantID": "P02",
            "date": "2021-09-15",
            "time": "00:00:00",
            "utterance": "카카오로 신청했지"
        },
        {
            "utteranceID": "U03",
            "turnID": "T02",
            "participantID": "P02",
            "date": "2021-09-15",
            "time": "00:00:00",
            "utterance": "너는 했냐"
        },
        {
            "utteranceID": "U04",
            "turnID": "T03",
            "participantID": "P01",
            "date": "2021-09-15",
            "time": "00:00:00",
            "utterance": "나는 내일 금요일 신청이야 어떻게 하는거야?"
        },
        {
            "utteranceID": "U05",
            "turnID": "T04",
            "participantID": "P02",
            "date": "2021-09-15",
            "time": "00:00:00",
            "utterance": "쉬워 걱정마 나는 애들껏까지 받았어"
        },
        {
            "utteranceID": "U06",
            "turnID": "T05",
            "participantID": "P01",
            "date": "2021-09-15",
            "time": "00:00:00",
            "utterance": "꽁돈 생기니까 좋긴 한데 우리 나라 괜찮나모르겠다"
        },
        {
            "utteranceID": "U07",
            "turnID": "T06",
            "participantID": "P02",
            "date": "2021-09-15",
            "time": "00:00:00",
            "utterance": "세금 많이 걷겠지"
        },
        {
            "utteranceID": "U08",
            "turnID": "T06",
            "participantID": "P02",
            "date": "2021-09-15",
            "time": "00:00:00",
            "utterance": "그래서 일하는 놈들만 죽어나는거여"
        },
        {
            "utteranceID": "U09",
            "turnID": "T07",
            "participantID": "P01",
            "date": "2021-09-15",
            "time": "00:00:00",
            "utterance": "정치인들 월급이나 삭감했음 좋겠다"
        },
        {
            "utteranceID": "U10",
            "turnID": "T07",
            "participantID": "P01",
            "date": "2021-09-15",
            "time": "00:00:00",
            "utterance": "근데 저런것도 정치인 머리속에서 나온건가"
        },
        {
            "utteranceID": "U11",
            "turnID": "T08",
            "participantID": "P02",
            "date": "2021-09-15",
            "time": "00:00:00",
            "utterance": "밥값해야지"
        },
        {
            "utteranceID": "U12",
            "turnID": "T08",
            "participantID": "P02",
            "date": "2021-09-15",
            "time": "00:00:00",
            "utterance": "월급 많이 받으면 그만큼 국민위해 뭔가 해야지"
        },
        {
            "utteranceID": "U13",
            "turnID": "T09",
            "participantID": "P01",
            "date": "2021-09-15",
            "time": "00:00:00",
            "utterance": "군인월급도 인상된다더라"
        },
        {
            "utteranceID": "U14",
            "turnID": "T10",
            "participantID": "P02",
            "date": "2021-09-15",
            "time": "00:00:00",
            "utterance": "올라야지 누가 군대가것냐"
        },
        {
            "utteranceID": "U15",
            "turnID": "T11",
            "participantID": "P01",
            "date": "2021-09-15",
            "time": "00:00:00",
            "utterance": "아니 인상하는거 반대안하는데 나랏돈이 진짜 많은가 해서"
        },
        {
            "utteranceID": "U16",
            "turnID": "T12",
            "participantID": "P02",
            "date": "2021-09-15",
            "time": "00:00:00",
            "utterance": "다 굴러가게 되있응께 걱정마셔"
        },
        {
            "utteranceID": "U17",
            "turnID": "T13",
            "participantID": "P01",
            "date": "2021-09-15",
            "time": "00:00:00",
            "utterance": "누굴 뽑아야할지 모르겠음"
        },
        {
            "utteranceID": "U18",
            "turnID": "T13",
            "participantID": "P01",
            "date": "2021-09-15",
            "time": "00:00:00",
            "utterance": "맘카페에 한전 민양화 된다고 난리고"
        },
        {
            "utteranceID": "U19",
            "turnID": "T14",
            "participantID": "P02",
            "date": "2021-09-15",
            "time": "00:00:00",
            "utterance": "뽑을 인물이 없긴하지"
        },
        {
            "utteranceID": "U20",
            "turnID": "T14",
            "participantID": "P02",
            "date": "2021-09-15",
            "time": "00:00:00",
            "utterance": "정치인들 다 거기서 거기 같다"
        },
        {
            "utteranceID": "U21",
            "turnID": "T15",
            "participantID": "P01",
            "date": "2021-09-15",
            "time": "00:00:00",
            "utterance": "내말이 누가 더 훔쳐먹다 걸리냐 그거 아니여"
        },
        {
            "utteranceID": "U22",
            "turnID": "T15",
            "participantID": "P01",
            "date": "2021-09-15",
            "time": "00:00:00",
            "utterance": "법도 허술하고"
        },
        {
            "utteranceID": "U23",
            "turnID": "T16",
            "participantID": "P02",
            "date": "2021-09-15",
            "time": "00:00:00",
            "utterance": "전자발찌 그거나 강화했음 좋겠다"
        },
        {
            "utteranceID": "U24",
            "turnID": "T16",
            "participantID": "P02",
            "date": "2021-09-15",
            "time": "00:00:00",
            "utterance": "안설치고 다니게"
        }
    ]
}