    "body": [
        {
            "utteranceID": "U01",
            "turnID": "T01",
            "participantID": "P01",
            "date": "2021-10-01",
            "time": "00:00:00",
            "utterance": "키키 겁나 웃기네 인정..."
        },
        {
            "utteranceID": "U02",
            "turnID": "T01",
            "participantID": "P01",
            "date": "2021-10-01",
            "time": "00:00:00",
            "utterance": "아 너 백신 맞았냐"
        },
        {
            "utteranceID": "U03",
            "turnID": "T02",
            "participantID": "P02",
            "date": "2021-10-01",
            "time": "00:00:00",
            "utterance": "아 맞았지 넌 왜 안 맞아"
        },
        {
            "utteranceID": "U04",
            "turnID": "T03",
            "participantID": "P01",
            "date": "2021-10-01",
            "time": "00:00:00",
            "utterance": "아 진짜? 나 너무 신청이 귀찮아"
        },
        {
            "utteranceID": "U05",
            "turnID": "T04",
            "participantID": "P02",
            "date": "2021-10-01",
            "time": "00:00:00",
            "utterance": "엥 그냥 버튼 한번 누르면 되는데"
        },
        {
            "utteranceID": "U06",
            "turnID": "T05",
            "participantID": "P01",
            "date": "2021-10-01",
            "time": "00:00:00",
            "utterance": "그걸 누르려고 사이트를 찾아서 들어가야 하잖아 키키"
        },
        {
            "utteranceID": "U07",
            "turnID": "T06",
            "participantID": "P02",
            "date": "2021-10-01",
            "time": "00:00:00",
            "utterance": "키키 야 어쨌든 맞아야 해"
        },
        {
            "utteranceID": "U08",
            "turnID": "T06",
            "participantID": "P02",
            "date": "2021-10-01",
            "time": "00:00:00",
            "utterance": "지금 안 맞으면 얀센 맞는다던데?"
        },
        {
            "utteranceID": "U09",
            "turnID": "T07",
            "participantID": "P01",
            "date": "2021-10-01",
            "time": "00:00:00",
            "utterance": "아옹... 근데 백신 여론이 으마으마하게 좋은 편은 아니니까 굳이 ...? 이런 느낌이라 ..."
        },
        {
            "utteranceID": "U10",
            "turnID": "T08",
            "participantID": "P02",
            "date": "2021-10-01",
            "time": "00:00:00",
            "utterance": "얀센이 진짜 아프다던데,"
        },
        {
            "utteranceID": "U11",
            "turnID": "T08",
            "participantID": "P02",
            "date": "2021-10-01",
            "time": "00:00:00",
            "utterance": "지금 모더나 풀리기 시작했으니까 후닥닥 맞아야 돼"
        },
        {
            "utteranceID": "U12",
            "turnID": "T09",
            "participantID": "P01",
            "date": "2021-10-01",
            "time": "00:00:00",
            "utterance": "와 백신 종류가 왜 이렇게 많아?"
        },
        {
            "utteranceID": "U13",
            "turnID": "T10",
            "participantID": "P02",
            "date": "2021-10-01",
            "time": "00:00:00",
            "utterance": "4개야 키키"
        },
        {
            "utteranceID": "U14",
            "turnID": "T10",
            "participantID": "P02",
            "date": "2021-10-01",
            "time": "00:00:00",
            "utterance": "우린 화이자랑 모더나밖에 안돼"
        },
        {
            "utteranceID": "U15",
            "turnID": "T11",
            "participantID": "P01",
            "date": "2021-10-01",
            "time": "00:00:00",
            "utterance": "왜 ? 다른 건 우리 주기 싫다 그래...?"
        },
        {
            "utteranceID": "U16",
            "turnID": "T12",
            "participantID": "P02",
            "date": "2021-10-01",
            "time": "00:00:00",
            "utterance": "나이대 별로 다른 것 뿐이야,"
        },
        {
            "utteranceID": "U17",
            "turnID": "T13",
            "participantID": "P01",
            "date": "2021-10-01",
            "time": "00:00:00",
            "utterance": "앙 ... 나는 또 서운할 뻔했잖아"
        },
        {
            "utteranceID": "U18",
            "turnID": "T14",
            "participantID": "P02",
            "date": "2021-10-01",
            "time": "00:00:00",
            "utterance": "언능 맞아"
        },
        {
            "utteranceID": "U19",
            "turnID": "T14",
            "participantID": "P02",
            "date": "2021-10-01",
            "time": "00:00:00",
            "utterance": "그거 백신 안 맞으면 이제 제한 걸 수도 있대"
        },
        {
            "utteranceID": "U20",
            "turnID": "T15",
            "participantID": "P01",
            "date": "2021-10-01",
            "time": "00:00:00",
            "utterance": "엥 진짜? 그래서 요즘 친구들이 백신 맞았냐고 그렇게 물어보는 건가?"
        },
        {
            "utteranceID": "U21",
            "turnID": "T15",
            "participantID": "P01",
            "date": "2021-10-01",
            "time": "00:00:00",
            "utterance": "빨리 맞으라던데"
        },
        {
            "utteranceID": "U22",
            "turnID": "T16",
            "participantID": "P02",
            "date": "2021-10-01",
            "time": "00:00:00",
            "utterance": "어디 가거나 밥 먹거나 타지 가거나 그런 거 제한 건다는 얘기 있어"
        }
    ]
}