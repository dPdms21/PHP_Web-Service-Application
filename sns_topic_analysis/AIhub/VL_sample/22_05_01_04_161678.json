    "body": [
        {
            "utteranceID": "U01",
            "turnID": "T01",
            "participantID": "P01",
            "date": "2021-11-17",
            "time": "00:00:00",
            "utterance": "인도 뉴델리에 있는 야무나강 수면이 폐수에서 나온 독성 거품으로 뒤덮였대"
        },
        {
            "utteranceID": "U02",
            "turnID": "T02",
            "participantID": "P02",
            "date": "2021-11-17",
            "time": "00:00:00",
            "utterance": "헐 그럼 강 다 썩은 거야?"
        },
        {
            "utteranceID": "U03",
            "turnID": "T03",
            "participantID": "P01",
            "date": "2021-11-17",
            "time": "00:00:00",
            "utterance": "응 ㅠㅠ 하수와 인근 농장 살충제, 산업 폐수가 흘러 들어오면서 수년에 걸쳐 더렵혀졌다네"
        },
        {
            "utteranceID": "U04",
            "turnID": "T04",
            "participantID": "P02",
            "date": "2021-11-17",
            "time": "00:00:00",
            "utterance": "헐 강 복구하는 건 어렵대?"
        },
        {
            "utteranceID": "U05",
            "turnID": "T05",
            "participantID": "P01",
            "date": "2021-11-17",
            "time": "00:00:00",
            "utterance": "아직 방법을 찾고 있는 것 같아 ㅠㅠ"
        },
        {
            "utteranceID": "U06",
            "turnID": "T05",
            "participantID": "P01",
            "date": "2021-11-17",
            "time": "00:00:00",
            "utterance": "근데 거기서 힌두교 태양신 축제가 열렸대 ㅠㅠ"
        },
        {
            "utteranceID": "U07",
            "turnID": "T06",
            "participantID": "P02",
            "date": "2021-11-17",
            "time": "00:00:00",
            "utterance": "뭐야 모시는 신 축제를 썩은 곳에서 해 키키"
        },
        {
            "utteranceID": "U08",
            "turnID": "T07",
            "participantID": "P01",
            "date": "2021-11-17",
            "time": "00:00:00",
            "utterance": "매년 하는 축제라 그런가 봐"
        },
        {
            "utteranceID": "U09",
            "turnID": "T07",
            "participantID": "P01",
            "date": "2021-11-17",
            "time": "00:00:00",
            "utterance": "나는 이해가 안 가지만... ㅠㅠ"
        },
        {
            "utteranceID": "U10",
            "turnID": "T08",
            "participantID": "P02",
            "date": "2021-11-17",
            "time": "00:00:00",
            "utterance": "응 나도 이해 안 간다 키키"
        },
        {
            "utteranceID": "U11",
            "turnID": "T08",
            "participantID": "P02",
            "date": "2021-11-17",
            "time": "00:00:00",
            "utterance": "좀 미루던가 장소를 옮겨야지 키키"
        },
        {
            "utteranceID": "U12",
            "turnID": "T09",
            "participantID": "P01",
            "date": "2021-11-17",
            "time": "00:00:00",
            "utterance": "맞아 ㅠㅠ"
        },
        {
            "utteranceID": "U13",
            "turnID": "T09",
            "participantID": "P01",
            "date": "2021-11-17",
            "time": "00:00:00",
            "utterance": "그 강에 흐르는 물이 지역 주민들 주요 식수원이라는데 걱정이야 ㅠㅠ"
        },
        {
            "utteranceID": "U14",
            "turnID": "T10",
            "participantID": "P02",
            "date": "2021-11-17",
            "time": "00:00:00",
            "utterance": "헐 주요 식수원이면 심각한데 복구 작업 빠르게 들어가야지"
        },
        {
            "utteranceID": "U15",
            "turnID": "T11",
            "participantID": "P01",
            "date": "2021-11-17",
            "time": "00:00:00",
            "utterance": "그러니까 ㅠㅠ"
        },
        {
            "utteranceID": "U16",
            "turnID": "T11",
            "participantID": "P01",
            "date": "2021-11-17",
            "time": "00:00:00",
            "utterance": "아직 발원지 먼저 찾고 있는 것 같아"
        },
        {
            "utteranceID": "U17",
            "turnID": "T12",
            "participantID": "P02",
            "date": "2021-11-17",
            "time": "00:00:00",
            "utterance": "어딘지 찾고 복구 작업도 해야지"
        },
        {
            "utteranceID": "U18",
            "turnID": "T12",
            "participantID": "P02",
            "date": "2021-11-17",
            "time": "00:00:00",
            "utterance": "어휴 우리나라는 좋은 나라야 감사해야 해 진짜"
        }
    ]
}