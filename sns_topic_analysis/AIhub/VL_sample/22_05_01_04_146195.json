    "body": [
        {
            "utteranceID": "U01",
            "turnID": "T01",
            "participantID": "P01",
            "date": "2021-11-12",
            "time": "00:00:00",
            "utterance": "해외에서는 반려동물로 악어도 키운데 ㅠㅠ"
        },
        {
            "utteranceID": "U02",
            "turnID": "T02",
            "participantID": "P02",
            "date": "2021-11-12",
            "time": "00:00:00",
            "utterance": "와 대박이네 난 무서울 듯..."
        },
        {
            "utteranceID": "U03",
            "turnID": "T03",
            "participantID": "P01",
            "date": "2021-11-12",
            "time": "00:00:00",
            "utterance": "나도 키키 악어한테 물리면서도 키운다고 하더라 ㅠㅠ"
        },
        {
            "utteranceID": "U04",
            "turnID": "T04",
            "participantID": "P02",
            "date": "2021-11-12",
            "time": "00:00:00",
            "utterance": "헉 물리면 바로 죽는 거 아니야? 하하"
        },
        {
            "utteranceID": "U05",
            "turnID": "T05",
            "participantID": "P01",
            "date": "2021-11-12",
            "time": "00:00:00",
            "utterance": "무섭긴 하지 ㅠㅠ"
        },
        {
            "utteranceID": "U06",
            "turnID": "T05",
            "participantID": "P01",
            "date": "2021-11-12",
            "time": "00:00:00",
            "utterance": "근데 그렇게 심하게 물리진 않았다고 하더라고"
        },
        {
            "utteranceID": "U07",
            "turnID": "T05",
            "participantID": "P01",
            "date": "2021-11-12",
            "time": "00:00:00",
            "utterance": "난 못 키울 듯 ㅠㅠ"
        },
        {
            "utteranceID": "U08",
            "turnID": "T06",
            "participantID": "P02",
            "date": "2021-11-12",
            "time": "00:00:00",
            "utterance": "하긴 곰도 키우고 호랑이도 키우고 하더라 외국은"
        },
        {
            "utteranceID": "U09",
            "turnID": "T07",
            "participantID": "P01",
            "date": "2021-11-12",
            "time": "00:00:00",
            "utterance": "헐 ... 곰도 집에서 반려동물로 키워?"
        },
        {
            "utteranceID": "U10",
            "turnID": "T08",
            "participantID": "P02",
            "date": "2021-11-12",
            "time": "00:00:00",
            "utterance": "응 러시아는 그렇다던데?"
        },
        {
            "utteranceID": "U11",
            "turnID": "T08",
            "participantID": "P02",
            "date": "2021-11-12",
            "time": "00:00:00",
            "utterance": "사진 봤었어 키키"
        },
        {
            "utteranceID": "U12",
            "turnID": "T09",
            "participantID": "P01",
            "date": "2021-11-12",
            "time": "00:00:00",
            "utterance": "와 대박이네 나도 곰 한번 키워보고 싶다 키키"
        },
        {
            "utteranceID": "U13",
            "turnID": "T10",
            "participantID": "P02",
            "date": "2021-11-12",
            "time": "00:00:00",
            "utterance": "곰 키우면 진짜 든든하긴 하겠다..."
        },
        {
            "utteranceID": "U14",
            "turnID": "T11",
            "participantID": "P01",
            "date": "2021-11-12",
            "time": "00:00:00",
            "utterance": "키키 그치?"
        },
        {
            "utteranceID": "U15",
            "turnID": "T11",
            "participantID": "P01",
            "date": "2021-11-12",
            "time": "00:00:00",
            "utterance": "도둑 절대 못 들어와 키키"
        },
        {
            "utteranceID": "U16",
            "turnID": "T12",
            "participantID": "P02",
            "date": "2021-11-12",
            "time": "00:00:00",
            "utterance": "도둑 들어오면 바로 도망가야 해 키키"
        }
    ]
}