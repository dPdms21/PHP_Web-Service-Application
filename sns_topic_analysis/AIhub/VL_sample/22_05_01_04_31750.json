    "body": [
        {
            "utteranceID": "U01",
            "turnID": "T01",
            "participantID": "P01",
            "date": "2021-09-23",
            "time": "00:00:00",
            "utterance": "다음 주 화요일 새벽에 애플이 공식 발표가 있대!"
        },
        {
            "utteranceID": "U02",
            "turnID": "T02",
            "participantID": "P02",
            "date": "2021-09-23",
            "time": "00:00:00",
            "utterance": "오 무슨 발표야? 신제품?"
        },
        {
            "utteranceID": "U03",
            "turnID": "T03",
            "participantID": "P01",
            "date": "2021-09-23",
            "time": "00:00:00",
            "utterance": "응 그런 것 같더라 키키 아이폰13이겠지?"
        },
        {
            "utteranceID": "U04",
            "turnID": "T04",
            "participantID": "P02",
            "date": "2021-09-23",
            "time": "00:00:00",
            "utterance": "헐 드디어 나오는구나"
        },
        {
            "utteranceID": "U05",
            "turnID": "T04",
            "participantID": "P02",
            "date": "2021-09-23",
            "time": "00:00:00",
            "utterance": "나도 사고 싶다 ㅠㅠ"
        },
        {
            "utteranceID": "U06",
            "turnID": "T05",
            "participantID": "P01",
            "date": "2021-09-23",
            "time": "00:00:00",
            "utterance": "그러니깐 키키 애플워치랑 에어팟도 나오는 것 같아"
        },
        {
            "utteranceID": "U07",
            "turnID": "T06",
            "participantID": "P02",
            "date": "2021-09-23",
            "time": "00:00:00",
            "utterance": "오 너 이번에 사려구?"
        },
        {
            "utteranceID": "U08",
            "turnID": "T07",
            "participantID": "P01",
            "date": "2021-09-23",
            "time": "00:00:00",
            "utterance": "응 내 핸드폰 너무 낡아서 13 질러본다!"
        },
        {
            "utteranceID": "U09",
            "turnID": "T08",
            "participantID": "P02",
            "date": "2021-09-23",
            "time": "00:00:00",
            "utterance": "부럽다ㅠㅠ 아이폰은 이상하게 포기 못하겠어"
        },
        {
            "utteranceID": "U10",
            "turnID": "T09",
            "participantID": "P01",
            "date": "2021-09-23",
            "time": "00:00:00",
            "utterance": "그치 나도 그래 키키 이번에 꽤 비싸 보이더라"
        },
        {
            "utteranceID": "U11",
            "turnID": "T10",
            "participantID": "P02",
            "date": "2021-09-23",
            "time": "00:00:00",
            "utterance": "정말? 이번에 나오는 건 얼마래?"
        },
        {
            "utteranceID": "U12",
            "turnID": "T11",
            "participantID": "P01",
            "date": "2021-09-23",
            "time": "00:00:00",
            "utterance": "150 정도 한대 키키"
        },
        {
            "utteranceID": "U13",
            "turnID": "T11",
            "participantID": "P01",
            "date": "2021-09-23",
            "time": "00:00:00",
            "utterance": "근데 아직 우리나라는 책정 안 됨"
        },
        {
            "utteranceID": "U14",
            "turnID": "T12",
            "participantID": "P02",
            "date": "2021-09-23",
            "time": "00:00:00",
            "utterance": "헉... 우리나라 들어오면서 더 비싸지는 거 아냐?"
        },
        {
            "utteranceID": "U15",
            "turnID": "T13",
            "participantID": "P01",
            "date": "2021-09-23",
            "time": "00:00:00",
            "utterance": "그럴 수도 있겠다 키키 아직 루머가 많아서 그냥 흘러 듣지 뭐~"
        },
        {
            "utteranceID": "U16",
            "turnID": "T14",
            "participantID": "P02",
            "date": "2021-09-23",
            "time": "00:00:00",
            "utterance": "키키 그래도 바꿀 수 있어서 부럽다 할부야?"
        },
        {
            "utteranceID": "U17",
            "turnID": "T15",
            "participantID": "P01",
            "date": "2021-09-23",
            "time": "00:00:00",
            "utterance": "응 무이자 할부 때려서 해야지 ㅠㅠ"
        },
        {
            "utteranceID": "U18",
            "turnID": "T16",
            "participantID": "P02",
            "date": "2021-09-23",
            "time": "00:00:00",
            "utterance": "키키 바꾸면 구경 시켜줘 나도 키키"
        }
    ]
}